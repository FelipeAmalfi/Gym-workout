{
  "name": "gym-workout-lc",
  "version": "1.0.1",
  "description": "AI-powered workout system using LangChain, RAG, and PostgreSQL",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "node --env-file .env src/index.ts",
    "dev": "node --watch --inspect --env-file .env src/index.ts",
    "ingest": "node --env-file .env scripts/ingest.ts",
    "infra:up": "docker compose up -d --wait",
    "infra:down": "docker compose down --volumes",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:graph": "vitest run --project graph",
    "test:api": "vitest run --project api",
    "test:infra": "vitest run --project infra",
    "test:live": "vitest run tests/live --no-coverage",
    "test:coverage": "vitest run --coverage",
    "langgraph:serve": "npx @langchain/langgraph-cli dev"
  },
  "engines": {
    "node": ">=24.10.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@langchain/community": "^1.0.0",
    "@langchain/core": "^1.1.19",
    "@langchain/langgraph": "^1.1.3",
    "@langchain/openai": "^1.2.5",
    "csv-parse": "^5.5.6",
    "fastify": "^5.7.4",
    "langchain": "^1.2.17",
    "pg": "^8.13.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^24.10.12",
    "@types/pg": "^8.11.13",
    "@vitest/coverage-v8": "^4.1.5",
    "testcontainers": "^11.14.0",
    "vitest": "^4.1.5"
  }
}
